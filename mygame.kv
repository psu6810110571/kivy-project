<GameScreen>:
    # 1. ตั้งค่าสีพื้นหลังให้เป็นโทนสีน้ำเงินเข้ม/ม่วง แบบในรูป
    canvas.before:
        Color:
            rgba: 0.08, 0.06, 0.14, 1 
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: 30
        spacing: 15

        # 2. ส่วนคำถาม (ทำตัวหนังสือสีส้มให้เด่น)
        Label:
            id: question_text
            text: "คำถามจะแสดงที่นี่"
            font_name: 'THSarabunNew.ttf'
            font_size: '35sp'
            halign: 'center'
            color: 1, 0.4, 0, 1  # สีข้อความส้ม/ทอง

        # 3. รูปอาจารย์
        Button:
            size_hint: (None, None)
            size: (160, 160)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0 # ซ่อนกรอบปุ่ม
            on_release: root.show_hint()
            
            Image:
                source: 'hint_professor.jpg'
                center_x: self.parent.center_x
                center_y: self.parent.center_y
                size: self.parent.size

        Label:
            id: hint_label
            text: ""
            font_name: 'THSarabunNew.ttf'
            color: 1, 0.8, 0.2, 1 
            font_size: '22sp'
            size_hint_y: 0.2

        # 4. เพิ่มส่วนตัวเลือก 4 ข้อ (แบ่งเป็น 2 คอลัมน์)
        GridLayout:
            cols: 2
            spacing: 15
            size_hint_y: 0.6

            Button:
                id: btn_choice1
                text: "ตัวเลือก A"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: '' # ลบเงาสีเทาเดิมออก
                background_color: 0.15, 0.1, 0.25, 1 # พื้นหลังปุ่มสีม่วงเข้ม
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

            Button:
                id: btn_choice2
                text: "ตัวเลือก B"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: ''
                background_color: 0.15, 0.1, 0.25, 1
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

            Button:
                id: btn_choice3
                text: "ตัวเลือก C"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: ''
                background_color: 0.15, 0.1, 0.25, 1
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

            Button:
                id: btn_choice4
                text: "ตัวเลือก D"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: ''
                background_color: 0.15, 0.1, 0.25, 1
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

        # 5. ปุ่มจำลองจบเกม (ทำสีแดงส้มเหมือนปุ่ม 'เริ่มภารกิจ')
        Button:
            text: "จำลองการจบเกม (ไปหน้าสรุปผล)"
            font_name: 'THSarabunNew.ttf'
            font_size: '22sp'
            size_hint: (0.8, 0.3)
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: 0.9, 0.2, 0.1, 1 
            on_release: root.manager.current = 'result'

<ResultScreen>:
    canvas.before:
        Color:
            rgba: 0.08, 0.06, 0.14, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        spacing: 20
        padding: 50

        Label:
            text: "สรุปผลการเล่น!"
            font_name: 'THSarabunNew.ttf'
            font_size: '45sp'
            color: 1, 0.4, 0, 1 # สีส้ม

        Label:
            id: final_score
            text: "คะแนนของคุณคือ: 0"
            font_name: 'THSarabunNew.ttf'
            font_size: '35sp'
            color: 1, 1, 1, 1

        Label:
            id: feedback_label
            text: "ข้อความชมเชยจะแสดงที่นี่"
            font_name: 'THSarabunNew.ttf'
            font_size: '28sp'
            color: 0.2, 0.8, 0.2, 1 

        Button:
            text: "เล่นอีกครั้ง"
            font_name: 'THSarabunNew.ttf'
            font_size: '28sp'
            size_hint: (0.6, 0.3)
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: 0.9, 0.2, 0.1, 1 
            on_release: root.manager.current = 'game'