#:import FadeTransition kivy.uix.screenmanager.FadeTransition

ScreenManager:
    transition: app.fade_transition()
    MenuScreen:
    BriefingScreen:    
    CategoryScreen:
    ModeScreen:        # <--- [เพิ่มบรรทัดนี้เข้ามา]

<MenuScreen>:
    name: 'menu'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.14, 0.04, 0.28, 0.50
        Ellipse:
            pos: -dp(140), self.height*0.30
            size: dp(460), dp(460)
        Color:
            rgba: 0.40, 0.10, 0.02, 0.38
        Ellipse:
            pos: self.width-dp(220), -dp(100)
            size: dp(400), dp(400)
        Color:
            rgba: 0.16, 0.16, 0.32, 0.28
        Line:
            points: [0, self.height*0.15, self.width, self.height*0.15]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.35, self.width, self.height*0.35]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.55, self.width, self.height*0.55]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.75, self.width, self.height*0.75]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.92, self.width, self.height*0.92]
            width: dp(0.6)
        Line:
            points: [self.width*0.22, 0, self.width*0.22, self.height]
            width: dp(0.6)
        Line:
            points: [self.width*0.50, 0, self.width*0.50, self.height]
            width: dp(0.6)
        Line:
            points: [self.width*0.78, 0, self.width*0.78, self.height]
            width: dp(0.6)
        Color:
            rgba: 1, 0.38, 0.08, 0.13
        Line:
            circle: self.width-dp(50), self.height-dp(50), dp(85)
            width: dp(0.8)
        Color:
            rgba: 1, 0.38, 0.08, 0.06
        Line:
            circle: self.width-dp(50), self.height-dp(50), dp(112)
            width: dp(0.5)
        Color:
            rgba: 0.5, 0.1, 0.9, 0.10
        Line:
            circle: dp(45), dp(45), dp(75)
            width: dp(0.8)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(30), dp(18)
        spacing: dp(0)

        BoxLayout:
            size_hint_y: None
            height: dp(3)
            canvas.before:
                Color:
                    rgba: 1, 0.38, 0.08, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

        Widget:
            size_hint_y: 0.01

        BombWidget:
            size_hint_y: 0.32

        Label:
            id: title_label
            text: '[b]BOMB QUIZ[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(50)
            color: 1, 0.38, 0.08, 1
            halign: 'center'
            valign: 'middle'
            size_hint_y: None
            height: dp(66)

        BoxLayout:
            size_hint: 0.52, None
            height: dp(2)
            pos_hint: {'center_x': 0.5}
            canvas.before:
                Color:
                    rgba: 1, 0.38, 0.08, 0.80
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 1, 0.38, 0.08, 0.18
                Rectangle:
                    pos: self.x, self.y-dp(4)
                    size: self.width, dp(10)

        Label:
            text: 'แข่งกับระเบิด  ตอบให้ทัน!'
            font_name: 'Sarabun'
            font_size: sp(17)
            color: 0.68, 0.68, 0.90, 1
            halign: 'center'
            size_hint_y: None
            height: dp(30)

        Widget:
            size_hint_y: 0.05

        BoxLayout:
            size_hint: 0.78, None
            height: dp(24)
            pos_hint: {'center_x': 0.5}
            Label:
                text: 'ชื่อผู้เล่น'
                font_name: 'Sarabun'
                font_size: sp(13)
                color: 1, 0.38, 0.08, 0.9
                halign: 'left'
                valign: 'middle'

        BoxLayout:
            size_hint: 0.78, None
            height: dp(54)
            pos_hint: {'center_x': 0.5}
            padding: dp(2)
            canvas.before:
                Color:
                    rgba: 1, 0.38, 0.08, 0.60
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]
                Color:
                    rgba: 0.06, 0.06, 0.16, 1
                RoundedRectangle:
                    pos: self.x+dp(2), self.y+dp(2)
                    size: self.width-dp(4), self.height-dp(4)
                    radius: [dp(10)]
            TextInput:
                id: player_name
                hint_text: 'พิมพ์ชื่อของคุณที่นี่...'
                font_name: 'Sarabun'
                font_size: sp(18)
                multiline: False
                halign: 'center'
                background_color: 0, 0, 0, 0
                background_normal: ''
                foreground_color: 1, 1, 1, 1
                cursor_color: 1, 0.5, 0.1, 1
                hint_text_color: 0.30, 0.30, 0.50, 1
                padding: dp(12), dp(14)

        Widget:
            size_hint_y: 0.04

        Button:
            id: start_btn
            text: '[b]  เริ่มภารกิจ!  [/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint: 0.78, None
            height: dp(62)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.go_to_category(player_name.text)
            canvas.before:
                Color:
                    rgba: 0.9, 0.2, 0.05, 0.25
                RoundedRectangle:
                    pos: self.x-dp(4), self.y-dp(4)
                    size: self.width+dp(8), self.height+dp(8)
                    radius: [dp(17)]
                Color:
                    rgba: 0.85, 0.18, 0.06, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(13)]
                Color:
                    rgba: 1, 1, 1, 0.07
                RoundedRectangle:
                    pos: self.x, self.top-self.height*0.45
                    size: self.width, self.height*0.45
                    radius: [dp(13), dp(13), 0, 0]

        Widget:
            size_hint_y: 0.03

        Label:
            text: 'TIME-ATTACK QUIZ  v1.0'
            font_name: 'Sarabun'
            font_size: sp(11)
            color: 0.24, 0.24, 0.40, 1
            halign: 'center'
            size_hint_y: None
            height: dp(20)

        Widget:
            size_hint_y: 0.01

        BoxLayout:
            size_hint_y: None
            height: dp(3)
            canvas.before:
                Color:
                    rgba: 0.45, 0.1, 0.85, 0.75
                Rectangle:
                    pos: self.pos
                    size: self.size

<CategoryScreen>:
    name: 'category'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.14, 0.04, 0.28, 0.50
        Ellipse:
            pos: -dp(140), self.height*0.30
            size: dp(460), dp(460)
        Color:
            rgba: 0.40, 0.10, 0.02, 0.38
        Ellipse:
            pos: self.width-dp(220), -dp(100)
            size: dp(400), dp(400)
            
    BoxLayout:
        orientation: 'vertical'
        padding: dp(40), dp(50)
        spacing: dp(25)

        Label:
            text: '[b]เลือกหมวดหมู่ภารกิจ[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(35)
            color: 1, 0.8, 0.2, 1
            size_hint_y: 0.2
        
        Button:
            text: '📘 ความรู้ทั่วไป'
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint_y: 0.2
            background_color: 0, 0, 0, 0
            on_press: app.btn_press_anim(self)
            on_release: app.select_category('general')   # <--- [แก้ไขเป็น select_category]
            canvas.before:
                Color:
                    rgba: 0.1, 0.5, 0.8, 0.8
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]
                Color:
                    rgba: 0.3, 0.8, 1, 0.4
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))
                    width: dp(1.2)

        Button:
            text: '🩺 สุขภาพ'
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint_y: 0.2
            background_color: 0, 0, 0, 0
            on_press: app.btn_press_anim(self)
            on_release: app.select_category('health')    # <--- [แก้ไขเป็น select_category]
            canvas.before:
                Color:
                    rgba: 0.1, 0.7, 0.3, 0.8
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]
                Color:
                    rgba: 0.4, 1, 0.5, 0.4
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))
                    width: dp(1.2)

        Button:
            text: '💻 วิชาการ / IT'
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint_y: 0.2
            background_color: 0, 0, 0, 0
            on_press: app.btn_press_anim(self)
            on_release: app.select_category('it')        # <--- [แก้ไขเป็น select_category]
            canvas.before:
                Color:
                    rgba: 0.5, 0.2, 0.8, 0.8
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]
                Color:
                    rgba: 0.8, 0.5, 1, 0.4
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))
                    width: dp(1.2)

        Widget:
            size_hint_y: 0.2

<BriefingScreen>:
    name: 'briefing'
    canvas.before:
        Color:
            rgba: 0.02, 0.08, 0.04, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.05, 0.22, 0.06, 0.35
        Ellipse:
            pos: -dp(80), self.height*0.20
            size: dp(350), dp(350)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(36), dp(50)
        spacing: dp(22)

        Label:
            text: '⚠️ MISSION BRIEFING'
            font_name: 'Sarabun'
            font_size: sp(22)
            color: 0.3, 1, 0.4, 1
            halign: 'center'
            size_hint_y: None
            height: dp(36)

        BoxLayout:
            size_hint_y: None
            height: dp(2)
            canvas.before:
                Color:
                    rgba: 0.2, 1, 0.3, 0.5
                Rectangle:
                    pos: self.pos
                    size: self.size

        Label:
            id: lbl_agent_name
            text: 'AGENT: ???'
            font_name: 'Sarabun'
            font_size: sp(28)
            bold: True
            color: 1, 0.85, 0.1, 1
            halign: 'center'
            size_hint_y: None
            height: dp(50)

        Label:
            id: lbl_briefing
            text: 'ระเบิดถูกวางไว้ในจุดลับ...\nคุณต้องตัดสายที่ถูกต้องก่อนหมดเวลา!'
            font_name: 'Sarabun'
            font_size: sp(17)
            color: 0.8, 0.95, 0.8, 1
            halign: 'center'
            valign: 'middle'
            text_size: self.width - dp(20), None
            size_hint_y: 0.4

        Widget:
            size_hint_y: 0.05

        Label:
            id: lbl_tap
            text: '— รับภารกิจด้านล่าง —'
            font_name: 'Sarabun'
            font_size: sp(15)
            color: 0.4, 0.8, 0.4, 0.7
            halign: 'center'
            size_hint_y: None
            height: dp(30)

        Widget:
            size_hint_y: 0.1

        Button:
            text: '[b]  รับภารกิจ!  [/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint: 0.70, None
            height: dp(56)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.root.current = 'category'
            canvas.before:
                Color:
                    rgba: 0.08, 0.55, 0.18, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Widget:
            size_hint_y: 0.05

# <--- [เพิ่มโค้ดส่วนนี้: หน้าจอ ModeScreen] --->
# ════════════ ModeScreen ════════════
<ModeScreen>:
    name: 'mode'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.18, 0.04, 0.04, 0.35
        Ellipse:
            pos: -dp(80), self.height*0.15
            size: dp(340), dp(340)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(32), dp(36)
        spacing: dp(16)

        Label:
            text: '[b]เลือกโหมดเกม[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(30)
            color: 1, 0.78, 0.18, 1
            size_hint_y: None
            height: dp(50)
            halign: 'center'

        Button:
            text: '👤   โหมดเดี่ยว'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('single')
            canvas.before:
                Color:
                    rgba: 0.08, 0.38, 0.70, 0.85
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Button:
            text: '👥   2 ผู้เล่น (ผลัดกัน)'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('2player')
            canvas.before:
                Color:
                    rgba: 0.06, 0.50, 0.30, 0.85
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Button:
            text: '💀   Sudden Death'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('sudden')
            canvas.before:
                Color:
                    rgba: 0.65, 0.08, 0.06, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Button:
            text: '📅   Daily Challenge'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('daily')
            canvas.before:
                Color:
                    rgba: 0.45, 0.30, 0.02, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Widget:
# <----------------------------------------->

# <--- [เพิ่มโค้ดส่วนนี้: หน้าจอ LevelScreen] --->
# ════════════ LevelScreen ════════════
<LevelScreen>:
    name: 'level'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.18, 0.04, 0.04, 0.38
        Ellipse:
            pos: -dp(100), self.height*0.20
            size: dp(360), dp(360)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(32), dp(40)
        spacing: dp(20)

        Label:
            text: '[b]เลือกระดับความยาก[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(30)
            color: 1, 0.78, 0.18, 1
            size_hint_y: None
            height: dp(52)
            halign: 'center'

        Button:
            text: '🟢   ง่าย  —  15 วิ / 4 สาย / 5 ข้อ'
            font_name: 'Sarabun'
            font_size: sp(19)
            size_hint_y: 0.20
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.start_game('easy')
            canvas.before:
                Color:
                    rgba: 0.06, 0.50, 0.20, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

        Button:
            text: '🟡   กลาง  —  10 วิ / 5 สาย / 7 ข้อ'
            font_name: 'Sarabun'
            font_size: sp(19)
            size_hint_y: 0.20
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.start_game('medium')
            canvas.before:
                Color:
                    rgba: 0.55, 0.42, 0.02, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

        Button:
            text: '🔴   ยาก  —  7 วิ / 6 สาย / 10 ข้อ'
            font_name: 'Sarabun'
            font_size: sp(19)
            size_hint_y: 0.20
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.start_game('hard')
            canvas.before:
                Color:
                    rgba: 0.72, 0.10, 0.05, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

        Widget:
# <----------------------------------------->