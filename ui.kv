#:import FadeTransition kivy.uix.screenmanager.FadeTransition

ScreenManager:
    transition: app.fade_transition()
    MenuScreen:
    BriefingScreen:
    CategoryScreen:
    ModeScreen:
    LevelScreen:
    Player2SetupScreen:
    GameScreen:
    ResultScreen:
    LeaderboardScreen:
    AchievementScreen:

# ════════════ MenuScreen ════════════
<MenuScreen>:
    name: 'menu'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.14, 0.04, 0.28, 0.50
        Ellipse:
            pos: -dp(140), self.height*0.30
            size: dp(460), dp(460)
        Color:
            rgba: 0.40, 0.10, 0.02, 0.38
        Ellipse:
            pos: self.width-dp(220), -dp(100)
            size: dp(400), dp(400)
        Color:
            rgba: 0.16, 0.16, 0.32, 0.28
        Line:
            points: [0, self.height*0.15, self.width, self.height*0.15]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.35, self.width, self.height*0.35]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.55, self.width, self.height*0.55]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.75, self.width, self.height*0.75]
            width: dp(0.6)
        Line:
            points: [0, self.height*0.92, self.width, self.height*0.92]
            width: dp(0.6)
        Line:
            points: [self.width*0.22, 0, self.width*0.22, self.height]
            width: dp(0.6)
        Line:
            points: [self.width*0.50, 0, self.width*0.50, self.height]
            width: dp(0.6)
        Line:
            points: [self.width*0.78, 0, self.width*0.78, self.height]
            width: dp(0.6)
        Color:
            rgba: 1, 0.38, 0.08, 0.13
        Line:
            circle: self.width-dp(50), self.height-dp(50), dp(85)
            width: dp(0.8)
        Color:
            rgba: 1, 0.38, 0.08, 0.06
        Line:
            circle: self.width-dp(50), self.height-dp(50), dp(112)
            width: dp(0.5)
        Color:
            rgba: 0.5, 0.1, 0.9, 0.10
        Line:
            circle: dp(45), dp(45), dp(75)
            width: dp(0.8)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(30), dp(18)
        spacing: dp(0)

        BoxLayout:
            size_hint_y: None
            height: dp(3)
            canvas.before:
                Color:
                    rgba: 1, 0.38, 0.08, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

        Widget:
            size_hint_y: 0.01

        BombWidget:
            size_hint_y: 0.32

        Label:
            id: title_label
            text: '[b]BOMB QUIZ[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(50)
            color: 1, 0.38, 0.08, 1
            halign: 'center'
            valign: 'middle'
            size_hint_y: None
            height: dp(66)

        BoxLayout:
            size_hint: 0.52, None
            height: dp(2)
            pos_hint: {'center_x': 0.5}
            canvas.before:
                Color:
                    rgba: 1, 0.38, 0.08, 0.80
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 1, 0.38, 0.08, 0.18
                Rectangle:
                    pos: self.x, self.y-dp(4)
                    size: self.width, dp(10)

        Label:
            text: 'แข่งกับระเบิด  ตอบให้ทัน!'
            font_name: 'Sarabun'
            font_size: sp(17)
            color: 0.68, 0.68, 0.90, 1
            halign: 'center'
            size_hint_y: None
            height: dp(30)

        Widget:
            size_hint_y: 0.05

        BoxLayout:
            size_hint: 0.78, None
            height: dp(24)
            pos_hint: {'center_x': 0.5}
            Label:
                text: 'ชื่อผู้เล่น'
                font_name: 'Sarabun'
                font_size: sp(13)
                color: 1, 0.38, 0.08, 0.9
                halign: 'left'
                valign: 'middle'

        BoxLayout:
            size_hint: 0.78, None
            height: dp(54)
            pos_hint: {'center_x': 0.5}
            padding: dp(2)
            canvas.before:
                Color:
                    rgba: 1, 0.38, 0.08, 0.60
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]
                Color:
                    rgba: 0.06, 0.06, 0.16, 1
                RoundedRectangle:
                    pos: self.x+dp(2), self.y+dp(2)
                    size: self.width-dp(4), self.height-dp(4)
                    radius: [dp(10)]
            TextInput:
                id: player_name
                hint_text: 'พิมพ์ชื่อของคุณที่นี่...'
                font_name: 'Sarabun'
                font_size: sp(18)
                multiline: False
                halign: 'center'
                background_color: 0, 0, 0, 0
                background_normal: ''
                foreground_color: 1, 1, 1, 1
                cursor_color: 1, 0.5, 0.1, 1
                hint_text_color: 0.30, 0.30, 0.50, 1
                padding: dp(12), dp(14)

        Widget:
            size_hint_y: 0.04

        Button:
            id: start_btn
            text: '[b]  เริ่มภารกิจ!  [/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint: 0.78, None
            height: dp(62)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.go_to_category(player_name.text)
            canvas.before:
                Color:
                    rgba: 0.9, 0.2, 0.05, 0.25
                RoundedRectangle:
                    pos: self.x-dp(4), self.y-dp(4)
                    size: self.width+dp(8), self.height+dp(8)
                    radius: [dp(17)]
                Color:
                    rgba: 0.85, 0.18, 0.06, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(13)]
                Color:
                    rgba: 1, 1, 1, 0.07
                RoundedRectangle:
                    pos: self.x, self.top-self.height*0.45
                    size: self.width, self.height*0.45
                    radius: [dp(13), dp(13), 0, 0]

        Widget:
            size_hint_y: 0.03

        BoxLayout:
            size_hint: None, None
            size: dp(260), dp(38)
            pos_hint: {'center_x': 0.5}
            spacing: dp(8)

            Button:
                text: '🏆 คะแนน'
                font_name: 'Sarabun'
                font_size: sp(14)
                background_color: 0, 0, 0, 0
                color: 0.85, 0.70, 1.0, 1
                on_press: app.btn_press_anim(self)
                on_release: app.show_leaderboard()
                canvas.before:
                    Color:
                        rgba: 0.28, 0.08, 0.55, 0.75
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

            Button:
                text: '🎖️ รางวัล'
                font_name: 'Sarabun'
                font_size: sp(14)
                background_color: 0, 0, 0, 0
                color: 1, 0.85, 0.2, 1
                on_press: app.btn_press_anim(self)
                on_release: app.show_achievements()
                canvas.before:
                    Color:
                        rgba: 0.45, 0.32, 0.02, 0.75
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        Widget:
            size_hint_y: 0.015

        Label:
            text: 'BOMB QUIZ  v4.0'
            font_name: 'Sarabun'
            font_size: sp(11)
            color: 0.24, 0.24, 0.40, 1
            halign: 'center'
            size_hint_y: None
            height: dp(20)

        Widget:
            size_hint_y: 0.01

        BoxLayout:
            size_hint_y: None
            height: dp(3)
            canvas.before:
                Color:
                    rgba: 0.45, 0.1, 0.85, 0.75
                Rectangle:
                    pos: self.pos
                    size: self.size

# ════════════ BriefingScreen ════════════
<BriefingScreen>:
    name: 'briefing'
    canvas.before:
        Color:
            rgba: 0.02, 0.08, 0.04, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.05, 0.22, 0.06, 0.35
        Ellipse:
            pos: -dp(80), self.height*0.20
            size: dp(350), dp(350)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(36), dp(50)
        spacing: dp(22)

        Label:
            text: '⚠️ MISSION BRIEFING'
            font_name: 'Sarabun'
            font_size: sp(22)
            color: 0.3, 1, 0.4, 1
            halign: 'center'
            size_hint_y: None
            height: dp(36)

        BoxLayout:
            size_hint_y: None
            height: dp(2)
            canvas.before:
                Color:
                    rgba: 0.2, 1, 0.3, 0.5
                Rectangle:
                    pos: self.pos
                    size: self.size

        Label:
            id: lbl_agent_name
            text: 'AGENT: ???'
            font_name: 'Sarabun'
            font_size: sp(28)
            bold: True
            color: 1, 0.85, 0.1, 1
            halign: 'center'
            size_hint_y: None
            height: dp(50)

        Label:
            id: lbl_briefing
            text: 'ระเบิดถูกวางไว้ในจุดลับ...\nคุณต้องตัดสายที่ถูกต้องก่อนหมดเวลา!'
            font_name: 'Sarabun'
            font_size: sp(17)
            color: 0.8, 0.95, 0.8, 1
            halign: 'center'
            valign: 'middle'
            text_size: self.width - dp(20), None
            size_hint_y: 0.4

        Widget:
            size_hint_y: 0.05

        Label:
            id: lbl_tap
            text: '— รับภารกิจด้านล่าง —'
            font_name: 'Sarabun'
            font_size: sp(15)
            color: 0.4, 0.8, 0.4, 0.7
            halign: 'center'
            size_hint_y: None
            height: dp(30)

        Widget:
            size_hint_y: 0.1

        Button:
            text: '[b]  รับภารกิจ!  [/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint: 0.70, None
            height: dp(56)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.root.current = 'category'
            canvas.before:
                Color:
                    rgba: 0.08, 0.55, 0.18, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Widget:
            size_hint_y: 0.05

# ════════════ CategoryScreen ════════════
<CategoryScreen>:
    name: 'category'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.14, 0.04, 0.28, 0.50
        Ellipse:
            pos: -dp(140), self.height*0.30
            size: dp(460), dp(460)
        Color:
            rgba: 0.40, 0.10, 0.02, 0.38
        Ellipse:
            pos: self.width-dp(220), -dp(100)
            size: dp(400), dp(400)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(40), dp(50)
        spacing: dp(25)

        Label:
            text: '[b]เลือกหมวดหมู่ภารกิจ[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(35)
            color: 1, 0.8, 0.2, 1
            size_hint_y: 0.2

        Button:
            text: '📘 ความรู้ทั่วไป'
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint_y: 0.2
            background_color: 0, 0, 0, 0
            on_press: app.btn_press_anim(self)
            on_release: app.select_category('general')
            canvas.before:
                Color:
                    rgba: 0.1, 0.5, 0.8, 0.8
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]
                Color:
                    rgba: 0.3, 0.8, 1, 0.4
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))
                    width: dp(1.2)

        Button:
            text: '🩺 สุขภาพ'
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint_y: 0.2
            background_color: 0, 0, 0, 0
            on_press: app.btn_press_anim(self)
            on_release: app.select_category('health')
            canvas.before:
                Color:
                    rgba: 0.1, 0.7, 0.3, 0.8
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]
                Color:
                    rgba: 0.4, 1, 0.5, 0.4
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))
                    width: dp(1.2)

        Button:
            text: '💻 วิชาการ / IT'
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint_y: 0.2
            background_color: 0, 0, 0, 0
            on_press: app.btn_press_anim(self)
            on_release: app.select_category('it')
            canvas.before:
                Color:
                    rgba: 0.5, 0.2, 0.8, 0.8
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]
                Color:
                    rgba: 0.8, 0.5, 1, 0.4
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))
                    width: dp(1.2)

        Widget:
            size_hint_y: 0.2

# ════════════ ModeScreen ════════════
<ModeScreen>:
    name: 'mode'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.18, 0.04, 0.04, 0.35
        Ellipse:
            pos: -dp(80), self.height*0.15
            size: dp(340), dp(340)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(32), dp(36)
        spacing: dp(16)

        Label:
            text: '[b]เลือกโหมดเกม[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(30)
            color: 1, 0.78, 0.18, 1
            size_hint_y: None
            height: dp(50)
            halign: 'center'

        Button:
            text: '👤   โหมดเดี่ยว'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('single')
            canvas.before:
                Color:
                    rgba: 0.08, 0.38, 0.70, 0.85
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Button:
            text: '👥   2 ผู้เล่น (ผลัดกัน)'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('2player')
            canvas.before:
                Color:
                    rgba: 0.06, 0.50, 0.30, 0.85
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Button:
            text: '💀   Sudden Death'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('sudden')
            canvas.before:
                Color:
                    rgba: 0.65, 0.08, 0.06, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Button:
            text: '📅   Daily Challenge'
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint_y: 0.16
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.set_mode('daily')
            canvas.before:
                Color:
                    rgba: 0.45, 0.30, 0.02, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Widget:

# ════════════ LevelScreen ════════════
<LevelScreen>:
    name: 'level'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.18, 0.04, 0.04, 0.38
        Ellipse:
            pos: -dp(100), self.height*0.20
            size: dp(360), dp(360)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(32), dp(40)
        spacing: dp(20)

        Label:
            text: '[b]เลือกระดับความยาก[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(30)
            color: 1, 0.78, 0.18, 1
            size_hint_y: None
            height: dp(52)
            halign: 'center'

        Button:
            text: '🟢   ง่าย  —  15 วิ / 4 สาย / 5 ข้อ'
            font_name: 'Sarabun'
            font_size: sp(19)
            size_hint_y: 0.20
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.start_game('easy')
            canvas.before:
                Color:
                    rgba: 0.06, 0.50, 0.20, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

        Button:
            text: '🟡   กลาง  —  10 วิ / 5 สาย / 7 ข้อ'
            font_name: 'Sarabun'
            font_size: sp(19)
            size_hint_y: 0.20
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.start_game('medium')
            canvas.before:
                Color:
                    rgba: 0.55, 0.42, 0.02, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

        Button:
            text: '🔴   ยาก  —  7 วิ / 6 สาย / 10 ข้อ'
            font_name: 'Sarabun'
            font_size: sp(19)
            size_hint_y: 0.20
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.start_game('hard')
            canvas.before:
                Color:
                    rgba: 0.72, 0.10, 0.05, 0.88
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

        Widget:

# ════════════ Player2SetupScreen ════════════
<Player2SetupScreen>:
    name: 'p2setup'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.04, 0.22, 0.06, 0.35
        Ellipse:
            pos: -dp(80), self.height*0.15
            size: dp(340), dp(340)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(36), dp(50)
        spacing: dp(24)

        Label:
            text: '[b]👥  2 ผู้เล่น[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(32)
            color: 0.3, 1, 0.5, 1
            halign: 'center'
            size_hint_y: None
            height: dp(56)

        Label:
            text: 'ชื่อผู้เล่นที่ 2'
            font_name: 'Sarabun'
            font_size: sp(14)
            color: 0.6, 1, 0.7, 0.9
            halign: 'left'
            size_hint_y: None
            height: dp(24)

        BoxLayout:
            size_hint_y: None
            height: dp(54)
            padding: dp(2)
            canvas.before:
                Color:
                    rgba: 0.2, 0.9, 0.3, 0.55
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]
                Color:
                    rgba: 0.05, 0.10, 0.06, 1
                RoundedRectangle:
                    pos: self.x+dp(2), self.y+dp(2)
                    size: self.width-dp(4), self.height-dp(4)
                    radius: [dp(10)]
            TextInput:
                id: p2_name
                hint_text: 'ชื่อผู้เล่น 2...'
                font_name: 'Sarabun'
                font_size: sp(18)
                multiline: False
                halign: 'center'
                background_color: 0, 0, 0, 0
                background_normal: ''
                foreground_color: 1, 1, 1, 1
                cursor_color: 0.3, 1, 0.5, 1
                hint_text_color: 0.3, 0.5, 0.35, 1
                padding: dp(12), dp(13)

        Widget:
            size_hint_y: 0.1

        Button:
            text: '[b]  เริ่มแข่ง!  [/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(22)
            size_hint: 0.75, None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.start_2player(p2_name.text)
            canvas.before:
                Color:
                    rgba: 0.08, 0.60, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(13)]

        Widget:

# ════════════ GameScreen ════════════
<GameScreen>:
    name: 'game'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.22, 0.04, 0.06, 0.30
        Ellipse:
            pos: -dp(80), self.height*0.08
            size: dp(340), dp(340)

    VignetteWidget:
        id: vignette
        pos: root.pos
        size: root.size

    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)

        # ── HUD Bar ──────────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(3)
            padding: dp(4), dp(5)
            canvas.before:
                Color:
                    rgba: 0.05, 0.05, 0.12, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                id: lbl_player
                text: 'P1: Agent'
                font_name: 'Sarabun'
                font_size: sp(12)
                color: 0.8, 0.8, 1, 1
                halign: 'center'
                size_hint_x: 0.26
                canvas.before:
                    Color:
                        rgba: 0.10, 0.10, 0.24, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

            Label:
                id: lbl_score
                text: '0 pts'
                font_name: 'Sarabun'
                font_size: sp(14)
                bold: True
                color: 1, 0.80, 0.1, 1
                halign: 'center'
                size_hint_x: 0.22
                canvas.before:
                    Color:
                        rgba: 0.15, 0.10, 0.02, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

            Label:
                id: lbl_lives
                text: '❤❤❤'
                font_name: 'Sarabun'
                font_size: sp(17)
                color: 1, 0.28, 0.28, 1
                halign: 'center'
                size_hint_x: 0.22
                canvas.before:
                    Color:
                        rgba: 0.18, 0.04, 0.04, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

            Label:
                id: lbl_timer
                text: '10'
                font_name: 'Sarabun'
                font_size: sp(24)
                bold: True
                color: 1, 0.45, 0.1, 1
                halign: 'center'
                size_hint_x: 0.14
                canvas.before:
                    Color:
                        rgba: 0.18, 0.08, 0.02, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

            Label:
                id: lbl_qnum
                text: '1/5'
                font_name: 'Sarabun'
                font_size: sp(12)
                color: 0.65, 0.65, 0.85, 1
                halign: 'center'
                size_hint_x: 0.16
                canvas.before:
                    Color:
                        rgba: 0.10, 0.10, 0.20, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

        # ── Timer Bar ─────────────────────────────────────────────────────
        ProgressBar:
            id: timer_bar
            size_hint_y: None
            height: dp(7)
            max: 15
            value: 15

        # ── Question Box ──────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: dp(72)
            padding: dp(10), dp(8)
            canvas.before:
                Color:
                    rgba: 0.07, 0.07, 0.18, 0.95
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
                Color:
                    rgba: 1, 0.38, 0.08, 0.28
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(10))
                    width: dp(1.2)
            Label:
                id: question_label
                text: 'รอคำถาม...'
                font_name: 'Sarabun'
                font_size: sp(16)
                color: 1, 1, 1, 1
                halign: 'center'
                valign: 'middle'
                text_size: self.size

        # ── Bomb Widget ───────────────────────────────────────────────────
        ClockBombWidget:
            id: bomb_widget
            size_hint_y: 0.42

        # ── Combo + Feedback ──────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            orientation: 'vertical'

            ComboDisplay:
                id: combo_display
                size_hint_y: 0.45
                size_hint_x: 1

            Label:
                id: feedback_label
                text: '✂ แตะปลายสายที่ตรงกับคำตอบ!'
                font_name: 'Sarabun'
                font_size: sp(13)
                color: 0.65, 0.85, 1, 0.9
                halign: 'center'
                size_hint_y: 0.55

        # ── Wire Answer Buttons ───────────────────────────────────────────
        GridLayout:
            id: wire_btn_container
            size_hint_y: None
            height: dp(88)
            cols: 3
            spacing: dp(5)
            padding: dp(6), dp(4)

        Widget:
            size_hint_y: None
            height: dp(6)

# ════════════ ResultScreen ════════════
<ResultScreen>:
    name: 'result'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.14, 0.04, 0.28, 0.40
        Ellipse:
            pos: -dp(80), self.height*0.22
            size: dp(350), dp(350)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(32), dp(40)
        spacing: dp(20)

        Label:
            id: lbl_result_title
            text: '🎉 ภารกิจสำเร็จ!'
            font_name: 'Sarabun'
            font_size: sp(34)
            bold: True
            color: 1, 0.85, 0.10, 1
            halign: 'center'
            size_hint_y: None
            height: dp(62)

        Label:
            id: lbl_result_agent
            text: 'AGENT: ???'
            font_name: 'Sarabun'
            font_size: sp(16)
            color: 0.70, 0.70, 1, 1
            halign: 'center'
            size_hint_y: None
            height: dp(30)

        Label:
            id: lbl_result_score
            text: '0 pts'
            font_name: 'Sarabun'
            font_size: sp(52)
            bold: True
            color: 1, 0.55, 0.10, 1
            halign: 'center'
            size_hint_y: None
            height: dp(90) 

        Label:
            id: lbl_result_stats
            text: ''
            font_name: 'Sarabun'
            font_size: sp(15)
            color: 0.75, 0.75, 0.95, 1
            halign: 'center'
            size_hint_y: None
            height: dp(32)

        Label:
            id: lbl_result_msg
            text: ''
            font_name: 'Sarabun'
            font_size: sp(18)
            color: 0.80, 0.80, 1, 1
            halign: 'center'
            size_hint_y: None
            height: dp(36)

        Label:
            id: lbl_rank
            text: ''
            font_name: 'Sarabun'
            font_size: sp(14)
            color: 1, 0.80, 0.20, 1
            halign: 'center'
            size_hint_y: None
            height: dp(28)

        Label:
            id: lbl_new_ach
            text: ''
            font_name: 'Sarabun'
            font_size: sp(14)
            color: 1, 0.90, 0.30, 1
            halign: 'center'
            size_hint_y: None
            height: dp(28)

        Widget:
            size_hint_y: 0.05

        Button:
            text: '[b]  เล่นอีกครั้ง  [/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(20)
            size_hint: 0.72, None
            height: dp(56)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.play_again()
            canvas.before:
                Color:
                    rgba: 0.88, 0.17, 0.05, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]

        BoxLayout:
            size_hint: None, None
            size: dp(240), dp(42)
            pos_hint: {'center_x': 0.5}
            spacing: dp(10)

            Button:
                text: '🏆 คะแนน'
                font_name: 'Sarabun'
                font_size: sp(14)
                background_color: 0, 0, 0, 0
                color: 0.85, 0.70, 1, 1
                on_press: app.btn_press_anim(self)
                on_release: app.show_leaderboard()
                canvas.before:
                    Color:
                        rgba: 0.25, 0.08, 0.50, 0.85
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

            Button:
                text: 'หน้าหลัก'
                font_name: 'Sarabun'
                font_size: sp(14)
                background_color: 0, 0, 0, 0
                color: 0.55, 0.55, 0.78, 1
                on_press: app.btn_press_anim(self)
                on_release: app.go_home()
                canvas.before:
                    Color:
                        rgba: 0.10, 0.10, 0.22, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        Widget:
            size_hint_y: 0.03

# ════════════ LeaderboardScreen ════════════
<LeaderboardScreen>:
    name: 'leaderboard'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.22, 0.08, 0.38, 0.32
        Ellipse:
            pos: -dp(100), self.height*0.28
            size: dp(380), dp(380)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(18), dp(18)
        spacing: dp(10)

        Label:
            text: '[b]🏆  LEADERBOARD[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(28)
            color: 1, 0.82, 0.12, 1
            size_hint_y: None
            height: dp(50)
            halign: 'center'

        BoxLayout:
            size_hint_y: None
            height: dp(2)
            canvas.before:
                Color:
                    rgba: 1, 0.75, 0.1, 0.5
                Rectangle:
                    pos: self.pos
                    size: self.size

        ScrollView:
            GridLayout:
                id: lb_grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(5)
                padding: dp(3), dp(3)

        Button:
            text: '← กลับ'
            font_name: 'Sarabun'
            font_size: sp(17)
            size_hint: 0.46, None
            height: dp(46)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            color: 0.7, 0.7, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.go_back_from_lb()
            canvas.before:
                Color:
                    rgba: 0.12, 0.12, 0.26, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(11)]

# ════════════ AchievementScreen ════════════
<AchievementScreen>:
    name: 'achievements'
    canvas.before:
        Color:
            rgba: 0.03, 0.02, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.30, 0.22, 0.02, 0.30
        Ellipse:
            pos: -dp(80), self.height*0.20
            size: dp(350), dp(350)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(18), dp(18)
        spacing: dp(10)

        Label:
            text: '[b]🎖️  ACHIEVEMENTS[/b]'
            markup: True
            font_name: 'Sarabun'
            font_size: sp(28)
            color: 1, 0.85, 0.15, 1
            size_hint_y: None
            height: dp(50)
            halign: 'center'

        BoxLayout:
            size_hint_y: None
            height: dp(2)
            canvas.before:
                Color:
                    rgba: 1, 0.82, 0.1, 0.5
                Rectangle:
                    pos: self.pos
                    size: self.size

        ScrollView:
            GridLayout:
                id: ach_grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(6)
                padding: dp(3), dp(3)

        Button:
            text: '← กลับ'
            font_name: 'Sarabun'
            font_size: sp(17)
            size_hint: 0.46, None
            height: dp(46)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            color: 0.7, 0.7, 1, 1
            on_press: app.btn_press_anim(self)
            on_release: app.root.current = 'menu'
            canvas.before:
                Color:
                    rgba: 0.12, 0.12, 0.26, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(11)]