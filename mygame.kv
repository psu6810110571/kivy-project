# --- ดีไซน์ของ Popup แจ้งผล ---
<AnswerPopup>:
    size_hint: 0.7, 0.45
    auto_dismiss: False  # บังคับให้ต้องกดปุ่มเพื่อปิด
    title_font: 'THSarabunNew.ttf'
    title_size: '35sp'
    title_align: 'center'
    separator_color: 1, 0.5, 0, 1 # เส้นคั่นสีส้ม
    
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 20

        Label:
            text: root.message
            font_name: 'THSarabunNew.ttf'
            font_size: '35sp'
            color: root.color_text
            halign: 'center'

        Button:
            text: "ไปข้อต่อไป >>"
            font_name: 'THSarabunNew.ttf'
            font_size: '28sp'
            size_hint_y: 0.4
            background_normal: ''
            background_color: 0.9, 0.4, 0.1, 1 # ปุ่มสีส้ม
            on_release: root.dismiss() # กดแล้วปิด Popup

# --- ดีไซน์หน้าเกมเพลย์ (เหมือนเดิม) ---
<GameScreen>:
    canvas.before:
        Color:
            rgba: 0.08, 0.06, 0.14, 1 
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: 30
        spacing: 15

        Label:
            id: question_text
            text: "คำถามจะแสดงที่นี่"
            font_name: 'THSarabunNew.ttf'
            font_size: '35sp'
            halign: 'center'
            color: 1, 0.4, 0, 1

        Button:
            size_hint: (None, None)
            size: (160, 160)
            pos_hint: {'center_x': 0.5}
            background_color: 0, 0, 0, 0
            on_release: root.show_hint()
            
            Image:
                source: 'hint_professor.jpg'
                center_x: self.parent.center_x
                center_y: self.parent.center_y
                size: self.parent.size

        Label:
            id: hint_label
            text: ""
            font_name: 'THSarabunNew.ttf'
            color: 1, 0.8, 0.2, 1 
            font_size: '22sp'
            size_hint_y: 0.2

        GridLayout:
            cols: 2
            spacing: 15
            size_hint_y: 0.6

            Button:
                id: btn_choice1
                text: "ตัวเลือก A"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: '' 
                background_color: 0.15, 0.1, 0.25, 1 
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

            Button:
                id: btn_choice2
                text: "ตัวเลือก B"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: ''
                background_color: 0.15, 0.1, 0.25, 1
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

            Button:
                id: btn_choice3
                text: "ตัวเลือก C"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: ''
                background_color: 0.15, 0.1, 0.25, 1
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

            Button:
                id: btn_choice4
                text: "ตัวเลือก D"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                background_normal: ''
                background_color: 0.15, 0.1, 0.25, 1
                color: 1, 1, 1, 1
                on_release: root.check_answer(self.text)

# --- ดีไซน์หน้าสรุปผล (เหมือนเดิม) ---
<ResultScreen>:
    canvas.before:
        Color:
            rgba: 0.08, 0.06, 0.14, 1
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        BoxLayout:
            orientation: 'vertical'
            size_hint: 0.85, 0.65
            pos_hint: {'center_x': 0.5, 'center_y': 0.6}
            padding: 20
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.15, 0.1, 0.25, 0.9  
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [25]  

            Label:
                text: "🎉 สรุปผลภารกิจ 🎉"
                font_name: 'THSarabunNew.ttf'
                font_size: '45sp'
                color: 1, 0.5, 0, 1  
                size_hint_y: 0.2

            Label:
                text: "คะแนนที่คุณทำได้"
                font_name: 'THSarabunNew.ttf'
                font_size: '26sp'
                color: 0.8, 0.8, 0.8, 1  
                size_hint_y: 0.1

            Label:
                id: final_score
                text: "0 / 10"
                font_name: 'THSarabunNew.ttf'
                font_size: '90sp'  
                color: 1, 0.8, 0.1, 1  
                bold: True
                size_hint_y: 0.4

            Label:
                id: feedback_label
                text: "ข้อความชมเชยจะแสดงที่นี่"
                font_name: 'THSarabunNew.ttf'
                font_size: '32sp'
                color: 0.3, 0.9, 0.3, 1  
                size_hint_y: 0.3

        Button:
            text: "เล่นอีกครั้ง (PLAY AGAIN)"
            font_name: 'THSarabunNew.ttf'
            font_size: '26sp'
            size_hint: 0.7, 0.12
            pos_hint: {'center_x': 0.5, 'y': 0.08}
            background_normal: ''
            background_color: 0.9, 0.2, 0.1, 1  
            on_release: root.manager.current = 'game'